{
  // ── Serilog configuration ─────────────────────────────────────
  // This section is read by LoggingConfiguration.cs via
  // .ReadFrom.Configuration(configuration).
  "Serilog": {
    "MinimumLevel": {
      // Default level for everything not explicitly overridden.
      "Default": "Debug",
      "Override": {
        // Silence the noisy ASP.NET Core internals in Development too.
        "Microsoft":                  "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System":                     "Warning"
      }
    }
  },

  // ── Seq configuration ─────────────────────────────────────────
  "Seq": {
    // Default local Seq server spun up via Docker (see README).
    // Override with an environment variable in Production:
    //   SEQ__SERVERURL=https://seq.yourcompany.com
    "ServerUrl": "http://localhost:5341",

    // API key for Seq authentication.
    // Leave empty when running Seq locally without auth.
    // In Production set via environment variable: SEQ__APIKEY=...
    "ApiKey": ""
  },

  // ── Standard ASP.NET Core host logging ───────────────────────
  // Serilog replaces this at runtime, but it acts as a fallback
  // if Serilog fails to initialise.
  "Logging": {
    "LogLevel": {
      "Default":   "Information",
      "Microsoft": "Warning"
    }
  },

  "AllowedHosts": "*"
}
