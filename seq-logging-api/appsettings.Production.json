{
  // Production overrides — less verbose, higher log levels.
  "Serilog": {
    "MinimumLevel": {
      // Only Warning and above in Production.
      // Your own namespaces stay at Information.
      "Default": "Warning",
      "Override": {
        "SeqLoggingApi":              "Information",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft":                  "Error",
        "System":                     "Error"
      }
    }
  }
}
